FROM python:3.11-slim
WORKDIR /app
COPY packages/agent/ ./agent/
COPY packages/ ./packages/
RUN pip install --no-cache-dir httpx aiohttp asyncio-mqtt
ENV ASSET_ID=edge-asset-001
ENV FABRIC_URL=http://fabric:8001

# ── Non-root runtime user (for K8s runAsNonRoot enforcement) ──
RUN groupadd --system --gid 65534 heli || true \
 && useradd  --system --uid 65534 --gid 65534 --no-create-home heli || true \
 && chown -R heli:heli /app
USER heli:heli
CMD ["python", "agent/agent.py"]
